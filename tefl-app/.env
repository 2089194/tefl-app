# Flask
SECRET_KEY=change-this-to-a-random-string-in-production

# Database - PostgreSQL
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://tefl_app:tefl_app@localhost:5432/tefl_app

# Whisper model size: tiny | base | small | medium | large
# base is recommended for CPU-only machines
WHISPER_MODEL=large

# Ollama model - must be pulled first with: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# Ollama server URL (default is fine if running locally)
OLLAMA_URL=http://localhost:11434
